---

<Layout
  title="Projects"
  description="View the project portfolio of WY Architect — residential, commercial, and institutional architectural projects in Melbourne, Victoria."
  canonical="https://www.wyarchitect.com.au/projects/"
>
  <!-- Page Hero -->
  <section class="relative pt-36 pb-20 overflow-hidden">
    <div class="absolute inset-0">
      <img
        src="/images/3-gold-court-front-be.jpg"
        alt="WY Architect Projects"
        class="w-full h-full object-cover"
        loading="eager"
      />
      <div class="absolute inset-0 bg-neutral-900/70"></div>
    </div>
    <div class="relative z-10 max-w-7xl mx-auto px-6 md:px-12">
      <p class="text-xs tracking-[0.3em] uppercase text-amber-400 mb-4">Our Work</p>
      <h1 class="font-heading text-5xl md:text-6xl text-white font-light">Project Gallery</h1>
    </div>
  </section>

  <!-- WYA Own Projects -->
  <section class="section-padding bg-white">
    <div class="max-w-7xl mx-auto">
      <div class="mb-12">
        <p class="text-xs tracking-[0.3em] uppercase text-amber-700 mb-4">WY Architect Projects</p>
        <h2 class="font-heading text-3xl md:text-4xl font-light">Our Own Work</h2>
      </div>
      <div class="grid grid-cols-1 md:grid-cols-2 gap-8">
        {wyaProjects.map(project => (
          <div class="group overflow-hidden bg-neutral-50">
            {project.noPhoto ? (
              <div class="h-72 bg-neutral-200 flex flex-col items-center justify-center text-neutral-400">
                <svg xmlns="http://www.w3.org/2000/svg" class="w-12 h-12 mb-3 opacity-40" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1" d="M4 16l4.586-4.586a2 2 0 012.828 0L16 16m-2-2l1.586-1.586a2 2 0 012.828 0L20 14m-6-6h.01M6 20h12a2 2 0 002-2V6a2 2 0 00-2-2H6a2 2 0 00-2 2v12a2 2 0 002 2z" />
                </svg>
                <p class="text-xs tracking-widest uppercase">Photography Coming Soon</p>
              </div>
            ) : (
              <div class="overflow-hidden h-72">
                <img
                  src={project.cover}
                  alt={project.name}
                  class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-700"
                  loading="lazy"
                />
              </div>
            )}
            <div class="p-6">
              <p class="text-xs tracking-widest uppercase text-amber-700 mb-1">{project.type}</p>
              <h3 class="font-heading text-xl font-light">{project.name}</h3>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Involved Projects with Disclaimer -->
  <section class="section-padding bg-neutral-50">
    <div class="max-w-7xl mx-auto">
      <div class="mb-8">
        <p class="text-xs tracking-[0.3em] uppercase text-amber-700 mb-4">Prior Experience</p>
        <h2 class="font-heading text-3xl md:text-4xl font-light mb-6">Projects I Was Involved In</h2>

        <!-- Disclaimer -->
        <div class="disclaimer-box mb-10 max-w-3xl">
          <p class="font-medium mb-1">Note on Prior Experience</p>
          <p>
            The projects shown below were completed during my time working with a previous architectural practice. I was involved in these projects in the capacity noted against each entry. These projects are presented to demonstrate the breadth of my professional experience and are not claimed as independent WY Architect commissions.
          </p>
        </div>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
        {involvedProjects.map(project => (
          <div class="group overflow-hidden bg-white">
            <div class="overflow-hidden h-56">
              <img
                src={project.cover}
                alt={project.name}
                class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-700"
                loading="lazy"
              />
            </div>
            <div class="p-5">
              <p class="text-xs tracking-widest uppercase text-amber-700 mb-1">{project.type}</p>
              <h3 class="font-heading text-lg font-light mb-2">{project.name}</h3>
              <p class="text-xs text-neutral-500 italic">{project.role}</p>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- CTA -->
  <section class="section-padding bg-neutral-900 text-white text-center">
    <div class="max-w-2xl mx-auto">
      <p class="text-xs tracking-[0.3em] uppercase text-amber-400 mb-4">Start Your Project</p>
      <h2 class="font-heading text-4xl md:text-5xl font-light mb-6">Have a Project in Mind?</h2>
      <p class="text-neutral-400 leading-relaxed mb-10">
        Contact us to discuss your architectural requirements and explore how WY Architect can help bring your vision to life.
      </p>
      <a href="/contact/" class="inline-block px-8 py-3 bg-white text-neutral-900 text-sm tracking-widest uppercase hover:bg-neutral-100 transition-colors duration-200">
        Get in Touch
      </a>
    </div>
  </section>
</Layout>
