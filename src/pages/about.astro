---
import Layout from '../layouts/Layout.astro';
---

<Layout
  title="About"
  description="Learn about WY Architect — a Melbourne-based architectural practice dedicated to innovative and sustainable design for residential, commercial, and institutional projects."
  canonical="https://www.wyarchitect.com.au/about/"
>
  <!-- Page Hero -->
  <section class="relative pt-36 pb-20 overflow-hidden">
    <div class="absolute inset-0">
      <img
        src="/images/49-johnson-st-1.jpg"
        alt="WY Architect — About"
        class="w-full h-full object-cover"
        loading="eager"
      />
      <div class="absolute inset-0 bg-neutral-900/70"></div>
    </div>
    <div class="relative z-10 max-w-7xl mx-auto px-6 md:px-12">
      <p class="text-xs tracking-[0.3em] uppercase text-amber-400 mb-4">Who We Are</p>
      <h1 class="font-heading text-5xl md:text-6xl text-white font-light">About WY Architect</h1>
    </div>
  </section>

  <!-- About Content -->
  <section class="section-padding bg-white">
    <div class="max-w-7xl mx-auto grid grid-cols-1 lg:grid-cols-2 gap-20 items-start">
      <div>
        <p class="text-xs tracking-[0.3em] uppercase text-amber-700 mb-4">Our Practice</p>
        <h2 class="font-heading text-3xl md:text-4xl font-light leading-tight mb-8">
          Dedicated to Design Excellence
        </h2>
        <div class="space-y-5 text-neutral-600 leading-relaxed">
          <p>
            WY Architect is a provider of architectural services, dedicated to bringing innovative and sustainable design solutions to our clients. We are committed to delivering exceptional design concepts that align with our clients' vision and needs.
          </p>
          <p>
            With a focus on creativity, functionality, and efficiency, we work closely with our clients to create spaces that inspire and enhance the way people live and work. Our expertise spans across residential, commercial, and institutional projects, and we take pride in our ability to transform ideas into reality.
          </p>
          <p>
            At WY Architect, we strive for excellence in every project we undertake, ensuring that our designs are not only visually stunning but also practical and cost-effective. Whether it's a new construction, renovation, or interior design, we are dedicated to exceeding our clients' expectations and elevating the standard of architectural excellence.
          </p>
        </div>
      </div>

      <div class="space-y-8">
        <!-- Values -->
        <div class="border-t border-neutral-200 pt-8">
          <h3 class="font-heading text-2xl font-light mb-6">Our Approach</h3>
          <div class="space-y-6">
            <div class="flex gap-6">
              <div class="flex-shrink-0 w-10 h-10 bg-neutral-900 flex items-center justify-center">
                <span class="text-white text-xs font-medium">01</span>
              </div>
              <div>
                <h4 class="font-medium text-neutral-900 mb-1">Client-Centred Design</h4>
                <p class="text-sm text-neutral-600 leading-relaxed">We offer personalised design solutions tailored to your specific needs and preferences, ensuring that your project reflects your unique vision, style, and budget.</p>
              </div>
            </div>
            <div class="flex gap-6">
              <div class="flex-shrink-0 w-10 h-10 bg-neutral-900 flex items-center justify-center">
                <span class="text-white text-xs font-medium">02</span>
              </div>
              <div>
                <h4 class="font-medium text-neutral-900 mb-1">Professional Expertise</h4>
                <p class="text-sm text-neutral-600 leading-relaxed">We bring professional expertise to every project, delivering high-quality, innovative design solutions that meet your requirements and expectations.</p>
              </div>
            </div>
            <div class="flex gap-6">
              <div class="flex-shrink-0 w-10 h-10 bg-neutral-900 flex items-center justify-center">
                <span class="text-white text-xs font-medium">03</span>
              </div>
              <div>
                <h4 class="font-medium text-neutral-900 mb-1">Sustainable Thinking</h4>
                <p class="text-sm text-neutral-600 leading-relaxed">Sustainability is integral to our design philosophy. We develop solutions that are practical, cost-effective, and considerate of their environmental context.</p>
              </div>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Image Gallery Strip -->
  <section class="bg-neutral-50 py-16">
    <div class="max-w-7xl mx-auto px-6 md:px-12">
      <div class="grid grid-cols-2 md:grid-cols-4 gap-4">
        <img src="/images/49-johnson-st-3.jpg" alt="49 Johnson Street" class="w-full h-48 object-cover" loading="lazy" />
        <img src="/images/55-57-brown-st-1.jpg" alt="55-57 Brown Street" class="w-full h-48 object-cover" loading="lazy" />
        <img src="/images/240-high-st-1.jpg" alt="240 High Street" class="w-full h-48 object-cover" loading="lazy" />
        <img src="/images/326-settlement-rd-2.jpg" alt="326 Settlement Road" class="w-full h-48 object-cover" loading="lazy" />
      </div>
    </div>
  </section>

  <!-- Contact CTA -->
  <section class="section-padding bg-neutral-900 text-white text-center">
    <div class="max-w-2xl mx-auto">
      <p class="text-xs tracking-[0.3em] uppercase text-amber-400 mb-4">Work With Us</p>
      <h2 class="font-heading text-4xl md:text-5xl font-light mb-6">Let's Create Something Together</h2>
      <p class="text-neutral-400 leading-relaxed mb-10">
        Contact us to discuss your project and find out how WY Architect can help bring your vision to life.
      </p>
      <a href="/contact/" class="inline-block px-8 py-3 bg-white text-neutral-900 text-sm tracking-widest uppercase hover:bg-neutral-100 transition-colors duration-200">
        Get in Touch
      </a>
    </div>
  </section>
</Layout>
